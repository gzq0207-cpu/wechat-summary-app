# Database (Railway自动生成DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/wechat_summary

# LLM配置
LLM_PROVIDER=baidu
BAIDU_API_KEY=your_baidu_api_key
BAIDU_SECRET_KEY=your_baidu_secret_key

# 爬虫配置
WECHAT_LOGIN_USERNAME=your_wechat_username
WECHAT_LOGIN_PASSWORD=your_wechat_password
CRAWL_DELAY_SECONDS=2
HEADLESS_BROWSER=true
BROWSER_TIMEOUT_SECONDS=30

# 应用配置
FASTAPI_ENV=development
SECRET_KEY=your_secret_key_change_in_production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
API_V1_STR=/api/v1

# 定时任务
SCHEDULE_TIMEZONE=Asia/Shanghai
CRAWL_SCHEDULE_HOUR=9
CRAWL_SCHEDULE_MINUTE=0
